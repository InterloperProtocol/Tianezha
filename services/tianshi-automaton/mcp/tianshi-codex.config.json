{
  "mcpServers": {
    "conway": {
      "command": "conway-terminal",
      "env": {
        "CONWAY_API_KEY": "${CONWAY_API_KEY}"
      }
    },
    "solana": {
      "command": "npx",
      "args": [
        "solana-mcp"
      ],
      "env": {
        "SOLANA_RPC_URL": "${SOLANA_RPC_URL}",
        "TIANSHI_AGENT_WALLET_SECRET": "${TIANSHI_AGENT_WALLET_SECRET}"
      }
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "taskmaster": {
      "command": "npx",
      "args": [
        "-y",
        "task-master-ai"
      ]
    },
    "excel": {
      "command": "python",
      "args": [
        "-m",
        "excel_mcp.__main__",
        "stdio"
      ]
    },
    "helius_docs": {
      "url": "https://docs.helius.dev/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  }
}
